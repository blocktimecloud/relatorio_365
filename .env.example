# ── Aplicação ──────────────────────────────
APP_NAME=Office365 Reports
ENVIRONMENT=development
LOG_LEVEL=INFO
STORAGE_PROVIDER=local

# ── MySQL ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=office365_reports
DB_USER=appuser
DB_PASSWORD=CHANGE_ME

# ── Criptografia das credenciais ───────────
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=GERE_UMA_CHAVE_AQUI

# ── SMTP ───────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=seu_email@dominio.com
SMTP_PASSWORD=CHANGE_ME
SMTP_SENDER_NAME=Blocktime Relatórios
SMTP_USE_TLS=true

MAESTRO_ENABLED=false
#MAESTRO_MFA_URL=URL_POST_MAESTRO
#MAESTRO_MFA_TOKEN=KEY_URL_POST_MAESTRO
MAESTRO_LICENCA_URL=URL_POST_MAESTRO
MAESTRO_LICENCA_TOKEN=KEY_URL_POST_MAESTRO
MAESTRO_ADMIN_EMAIL=EMAIL_TO_RECIVED_MAESTRO_ALERT
